#include <iostream>
#include <string>
#include <stdexcept>
#include <locale>

namespace mt {

    class Product {
    private:
        std::string name_;
        std::string description_;
        double price_;
        std::string place_;

        bool is_price_valid_(double price) const {
            return price >= 0;
        }

     

    protected:
        int expiration_days_;

    public:
        // конструктор по умолчанию
        Product()
            : name_("Не задано"),
            description_("Не задано"),
            price_(0),
            place_("Не указано"),
            expiration_days_(0) {
            std::cerr << "Вызван конструктор по умолчанию Product\n";
        }

        // конструктор с параметрами
        Product(const std::string& name,
            const std::string& description,
            double price,
            int expiration_days,
            const std::string& place)
            : name_(name),
            description_(description),
            price_(price),
            place_(place),
            expiration_days_(expiration_days) {

          

            if (!is_price_valid_(price_))
                throw std::invalid_argument("Цена не должна быть отрицательной");

            if (expiration_days_ < 0)
                throw std::invalid_argument("Срок годности не может быть отрицательным");

  

            std::cerr << "Вызван конструктор с параметрами Product\n";
        }

        // конструктор копирования
        Product(const Product& other)
            : name_(other.name_),
            description_(other.description_),
            price_(other.price_),
            place_(other.place_),
            expiration_days_(other.expiration_days_) {
            std::cerr << "Вызван конструктор копирования Product\n";
        }

        // деструктор
        ~Product() {
            std::cerr << "Вызван деструктор Product: " << name_ << "\n";
        }

      

       

        void set_description(const std::string& description) {
            description_ = description;
        }

        std::string get_description() const { return description_; }

        // сеттер на цену
        void set_price(double price) {
            if (!is_price_valid_(price))
                throw std::invalid_argument("Цена не должна быть меньше 0");
            price_ = price;
        }

        double get_price() const { return price_; }

        
        void set_expiration_days(int days) {
            if (days < 0)
                throw std::invalid_argument("Срок годности должен быть >= 0");
            expiration_days_ = days;
        }

        int get_expiration_days() const { return expiration_days_; }


        std::string get_place() const { return place_; }

        // вывод всей информации ()
        void print_info() const {
          
            std::cout << "Название: " << name_ << "\n";
            std::cout << "Описание: " << description_ << "\n";
            std::cout << "Цена: " << price_ << "\n";
            std::cout << "Срок годности: " << expiration_days_ << " дней\n";
            std::cout << "Место получения: " << place_ << "\n";
         
        }

       
        void print_where_to_get(const std::string& info) const {
            std::cout << "Купить можно в: " << place_ << "\n";
            std::cout << "Информация: " << info << "\n";
        }

        // уменьшение срока хранения 
        void reduce_expiration() {
            if (expiration_days_ == 0)
                throw std::logic_error("Срок годности истёк");
            expiration_days_--;
        }
    };

} 

int main() {
    setlocale(LC_ALL, "Ru");

    try {
        std::cout << "Товар по умолчанию\n";
        mt::Product p1;
        p1.print_info();

        std::cout << "\nТовар с параметрами\n";
        mt::Product p2("Сырок", "Ванильный", 59.9, 5, "Ларек у дома");
        p2.print_info();

        std::cout << "\nКопирование товара\n";
        mt::Product p3 = p2;
        p3.print_info();

        std::cout << "\nИзменение цены\n";
        p2.set_price(39.9);
        std::cout << "Новая цена: " << p2.get_price() << "\n";

        std::cout << "\nУменьшение срока годности\n";
        p2.reduce_expiration();
        std::cout << "Осталось дней: " << p2.get_expiration_days() << "\n";

        std::cout << "\nВ каком отделе\n";
        p2.print_where_to_get("Отдел молочной продукции");
    }
    catch (const std::exception& e) {
        std::cerr << "Ошибка!!!!: " << e.what() << "\n";
    }

    
    return 0;
}
